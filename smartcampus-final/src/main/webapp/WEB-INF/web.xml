<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         version="4.0">

    <!--
        Jersey Servlet Configuration — as taught in Tutorial Week 08 and 09.

        jersey.config.server.provider.packages tells Jersey to scan the entire
        com.smartcampus package tree and automatically discover:
          - @Path resource classes  (RoomResource, SensorResource, etc.)
          - @Provider exception mappers (RoomNotEmptyExceptionMapper, etc.)
          - @Provider filters  (ApiLoggingFilter)

        This is the same approach used in Tutorial Week 09 Step 5, updated to
        scan the parent com.smartcampus package so all sub-packages are included.

        The url-pattern /api/v1/* establishes the versioned entry point,
        consistent with the @ApplicationPath("/api/v1") on SmartCampusApplication.
    -->
    <servlet>
        <servlet-name>SmartCampusAPI</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>jersey.config.server.provider.packages</param-name>
            <param-value>com.smartcampus</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>SmartCampusAPI</servlet-name>
        <!-- All API calls must be prefixed with /api/v1/ -->
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>
